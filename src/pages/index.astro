---
import BarraDerecha from '../components/BarraDerecha.astro';
import Titulo from '../components/NombreTitulo.astro';
import ExperienciaLaboral from '../components/ExperienciaLaboral.astro';
import FormacionAcademica from '../components/FormacionAcademica.astro';
import CertificacionesExtra from '../components/CertificacionesExtra.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="cv-container">
	<BarraDerecha />
	<div class="main-content">
		<Titulo />
		<ExperienciaLaboral />
		<FormacionAcademica />
		<CertificacionesExtra />
	</div>
  </div>
</Layout>

<style>
  .cv-container {
    display: flex;
    justify-content: center;
    background-color: white;
    max-width: 1100px;
    margin: 0 auto;
  }

  .main-content {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (max-width: 768px) {
    .cv-container {
    	flex-direction: column;
    }
  }
</style>