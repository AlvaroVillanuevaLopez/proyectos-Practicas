---
import { SECCIONES, CONTACTODES, PERFILPROFESIONALDES, HABILIDADESDES, TECNOLOGÍASDES, IDIOMASDES } from "../constantes/constBarraDerecha.js"
import Foto from "../assets/foto.png"
import Linkedin from "../assets/linkedin.png"
import Location from "../assets/location.png"
import Mail from "../assets/mail.png"
import Phone from "../assets/phone.png"
---

<div class="bg-[#0074B7] w-full md:w-[300px] min-h-screen p-5 flex flex-col font-sans">
    
    <img src={Foto.src} alt="Foto de perfil" class="mb-4">

    <h2 class="text-white font-bold">{SECCIONES.contacto}</h2>
    <hr class="h-[5px] bg-white border-none my-[10px] mx-[2.5px]">
    
    <div class="space-y-2.5 mb-2.5">
        <div class="flex flex-row gap-2.5 items-center">
            <img src={Location.src} alt="" class="w-5 h-5 object-contain"/>
            <p class="text-white leading-[1.4] m-0">{CONTACTODES.location}</p>
        </div>
        <div class="flex flex-row gap-2.5 items-center">
            <img src={Phone.src} alt="" class="w-5 h-5 object-contain"/>
            <p class="text-white leading-[1.4] m-0">{CONTACTODES.phone}</p>
        </div>
        <div class="flex flex-row gap-2.5 items-center">
            <img src={Mail.src} alt="" class="w-5 h-5 object-contain"/>
            <p class="text-white leading-[1.4] m-0">{CONTACTODES.mail}</p>
        </div>
        <div class="flex flex-row gap-2.5 items-center">
            <img src={Linkedin.src} alt="" class="w-5 h-5 object-contain"/>
            <p class="text-white leading-[1.4] m-0">{CONTACTODES.linekdin}</p>
        </div>
    </div>

    <h2 class="text-white font-bold">{SECCIONES.perfil_profesional}</h2>
    <hr class="h-[5px] bg-white border-none my-[10px] mx-[2.5px]">
    <p class="text-white leading-[1.4] mb-2.5 text-justify">
        {PERFILPROFESIONALDES.descripcion}
    </p>

    <h2 class="text-white font-bold">{SECCIONES.habilidades}</h2>
    <hr class="h-[5px] bg-white border-none my-[10px] mx-[2.5px]">
    <div class="text-white leading-[1.4] mb-2.5">
        <p class="mb-2.5">{HABILIDADESDES.equipo}</p>
        <p class="mb-2.5">{HABILIDADESDES.creatividad}</p>
        <p class="mb-2.5">{HABILIDADESDES.disciplina}</p>
        <p class="mb-2.5">{HABILIDADESDES.asertividad}</p>
    </div>

    <h2 class="text-white font-bold">{SECCIONES.tecnologias}</h2>
    <hr class="h-[5px] bg-white border-none my-[10px] mx-[2.5px]">
    <div class="text-white leading-[1.4] mb-2.5">
        <p class="mb-2.5">{TECNOLOGÍASDES.google}</p>
        <p class="mb-2.5">{TECNOLOGÍASDES.word}</p>
        <p class="mb-2.5">{TECNOLOGÍASDES.sql}</p>
        <p class="mb-2.5">{TECNOLOGÍASDES.java}</p>
        <p class="mb-2.5">{TECNOLOGÍASDES.ia}</p>
        <p class="mb-2.5">{TECNOLOGÍASDES.html}</p>
    </div>

    <h2 class="text-white font-bold">{SECCIONES.idiomas}</h2>
    <hr class="h-[5px] bg-white border-none my-[10px] mx-[2.5px]">
    <p class="text-white leading-[1.4] mb-2.5">
        {IDIOMASDES.spanish} <br>
        {IDIOMASDES.english}
    </p>
</div>